# CTOS Mindfulness App Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ctos_db

# Session
SESSION_SECRET=your-secret-key-here-change-this-in-production

# Optional: API URL for iOS app (leave empty for local development)
# When deploying, set this to your production API URL
API_URL=

# Optional: Replit Auth (only needed if using Replit authentication)
# REPLIT_DOMAINS=your-domain.replit.dev
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# Server Port (default: 5000)
PORT=5000

# Node Environment
NODE_ENV=development
